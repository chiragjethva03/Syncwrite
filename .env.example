# ---- Database (Supabase Postgres) ----
# Pooled connection (used by the app at runtime). Supabase: "Connection pooling" URI, add ?pgbouncer=true
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection (used by Prisma migrations only). Supabase: "Direct connection" URI (port 5432)
DIRECT_URL="postgresql://postgres:PASSWORD@HOST:5432/postgres"

# ---- Auth.js ----
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-32+-char-random-secret"
# Google OAuth (optional — enables "Continue with Google").
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <origin>/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# ---- AI (Google Gemini) ----
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"
# Model id. Defaults to gemini-2.5-flash. Override if a model's free-tier
# quota is unavailable for your key (e.g. gemini-2.0-flash returns 429 limit:0).
GEMINI_MODEL="gemini-2.5-flash"

# ---- Signup email notifications (optional) ----
# Get an API key at https://resend.com (free tier). When both keys below are set,
# an email is sent to ADMIN_NOTIFY_EMAIL whenever a new account is created.
RESEND_API_KEY="re_your_resend_api_key"
ADMIN_NOTIFY_EMAIL="you@example.com"
# From address. For quick testing (no domain setup), keep the Resend sandbox
# sender below — it can only deliver to the email you registered with Resend.
NOTIFY_FROM_EMAIL="Syncwrite <onboarding@resend.dev>"

# ---- Tuning ----
# Max accepted sync payload size (bytes). Protects the server from OOM. Default 1 MiB.
MAX_SYNC_PAYLOAD_BYTES=1048576
